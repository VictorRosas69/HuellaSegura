# ─── Servidor ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Base de datos MySQL ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=huella_segura
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql

# Base de datos de pruebas (tests automatizados)
DB_NAME_TEST=huella_segura_test

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_minimo_32_chars
JWT_EXPIRES_IN=24h

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── Nodemailer (Gmail con contraseña de aplicación) ────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion_gmail

# ─── Cloudflare Turnstile ────────────────────────────────────
TURNSTILE_SECRET_KEY=tu_secret_key_de_turnstile

# ─── URLs ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
